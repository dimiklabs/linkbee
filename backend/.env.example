# Application
ENV=development
SERVER_ADDRESS=:8080
BASE_DOMAIN=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_FILE_PATH=

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-64-characters-long-for-hs512-security
JWT_ISSUER=linkbee-auth
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
MAX_SESSIONS=5

# Write / Master
DB_HOST_WRITE=localhost
DB_PORT_WRITE=5432
DB_USER_WRITE=postgres
DB_PASSWORD_WRITE=postgres
DB_NAME=linkbee
DB_MAX_OPEN_CONNECTION=10
DB_MAX_IDLE_CONNECTION=5

# Read / Replica — set to same as write for single-node dev
DB_HOST_READ=localhost
DB_PORT_READ=5432
DB_USER_READ=postgres
DB_PASSWORD_READ=postgres

# Valkey / Redis
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_TTL=3600

# Email (Mailpit for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@linkbee.io
EMAIL_FROM_NAME=Linkbee
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFY_TOKEN_TTL_HOURS=24

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# Facebook OAuth
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:8080/api/v1/auth/facebook/callback

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
RATE_LIMIT_LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_IP_MAX_ATTEMPTS=20
RATE_LIMIT_IP_WINDOW_MINUTES=15
RATE_LIMIT_IP_LOCKOUT_MINUTES=30
RATE_LIMIT_PROGRESSIVE_ENABLED=true
RATE_LIMIT_PROGRESSIVE_MULTIPLIER=2.0
RATE_LIMIT_PROGRESSIVE_MAX_MULTIPLIER=8.0

# Session
SESSION_REMEMBER_ME_ENABLED=true
SESSION_REMEMBER_ME_REFRESH_EXPIRY_DAYS=30
SESSION_TRACK_ACTIVITY=true
SESSION_ACTIVITY_UPDATE_INTERVAL_MINS=5

# Links
LINK_SLUG_LENGTH=5
LINK_DEFAULT_REDIRECT_TYPE=302
LINK_CACHE_TTL_SECONDS=86400
CLICK_QUEUE_BATCH_SIZE=100
CLICK_QUEUE_FLUSH_INTERVAL_SECONDS=5
DEMO_RATE_LIMIT_PER_IP=5
